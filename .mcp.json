{
  "mcpServers": {
    "devt-memory": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/bin/devt-memory-mcp.cjs"
      ],
      "env": {
        "DEVT_MCP_ALLOW_WRITES": "1"
      }
    },
    "devt-graphify": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/bin/devt-graphify-mcp.cjs"
      ]
    }
  }
}
