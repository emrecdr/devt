# Runtime state (per-project, not committed)
.devt/state/

# Semantic database (generated from playbook)
memory/semantic/*.db

# IDE/editor history
.history/

# Claude Code local settings (user-specific)
.claude/settings.local.json

# Claude Code per-agent persistent memory (project-scope, written by subagents at runtime)
.claude/agent-memory/

# Claude Code scheduled-task runtime locks
.claude/*.lock

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc

# Test/build artifacts
coverage/
dist/
build/
.pytest_cache/
skills-workspace/

# Node
node_modules/

# devt memory FTS5 index (regenerable from markdown)
.devt/memory/index.db

# devt MCP tool-call trace (v0.21.0+, append-only telemetry; safe to delete)
.devt/memory/_mcp-trace.jsonl

# devt memory export bundles (transient — share via explicit channel)
.devt/memory/export-*.json

# devt discovery suggestions (regenerated by `memory suggest` / `memory index`)
.devt/memory/_suggestions.md

# devt SOAK telemetry — runtime measurement scaffold, regenerated per soak cycle
.devt/SOAK.md
.devt/SOAK-baseline.json

# Graphify ephemeral cache
graphify-out/cache/

# Graphify per-machine manifest
graphify-out/manifest.json

# claude-mem local session DB
.claude-mem/mem.db
